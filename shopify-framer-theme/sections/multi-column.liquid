<section class="section multi-column section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container">
    {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
    <div class="multi-column__grid columns-{{ section.settings.columns }}">
      {% for block in section.blocks %}
        <article class="grid-card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != 'none' %}<span class="grid-card__icon">{% render 'icon', icon: block.settings.icon %}</span>{% endif %}
          <h3 class="grid-card__title">{{ block.settings.title }}</h3>
          <p class="grid-card__text">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{"name":"Multi-column","settings":[{"type":"text","id":"heading","label":"Heading","default":"Why choose us"},{"type":"text","id":"subheading","label":"Subheading"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"left"},{"type":"range","id":"columns","label":"Grid columns","min":2,"max":3,"step":1,"default":3},{"type":"color","id":"background_color","label":"Background","default":"#ffffff"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"blocks":[{"type":"icon","name":"Icon block","settings":[{"type":"select","id":"icon","label":"Icon","options":[{"value":"none","label":"None"},{"value":"star","label":"Star"},{"value":"quote","label":"Quote"}],"default":"star"},{"type":"text","id":"title","label":"Title"},{"type":"textarea","id":"text","label":"Text"}]}],"presets":[{"name":"Multi-column","blocks":[{"type":"icon"},{"type":"icon"},{"type":"icon"}]}]}
{% endschema %}
