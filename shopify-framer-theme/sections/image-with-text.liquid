<section class="section image-with-text section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container hero">
    <div>{% render 'responsive-image', image: section.settings.image %}</div>
    <div style="text-align:{{ section.settings.text_alignment }};">
      {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
      <div>{{ section.settings.text }}</div>
      {% render 'button', text: section.settings.button_text, link: section.settings.button_link, style: 'secondary' %}
    </div>
  </div>
</section>
{% schema %}
{"name":"Image with text","settings":[{"type":"text","id":"heading","label":"Heading","default":"Image with text"},{"type":"text","id":"subheading","label":"Subheading"},{"type":"richtext","id":"text","label":"Content","default":"<p>Share your brand story with visual detail.</p>"},{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"button_text","label":"Button text","default":"Learn more"},{"type":"url","id":"button_link","label":"Button link"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"left"},{"type":"color","id":"background_color","label":"Background","default":"#ffffff"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"presets":[{"name":"Image with text"}]}
{% endschema %}
