<section class="section call-to-action section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container" style="text-align:{{ section.settings.text_alignment }};">
    {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
    {% render 'button', text: section.settings.button_text, link: section.settings.button_link %}
  </div>
</section>
{% schema %}
{"name":"Call to action","settings":[{"type":"text","id":"heading","label":"Heading","default":"Ready to get started?"},{"type":"text","id":"subheading","label":"Subheading","default":"Launch your next product with confidence."},{"type":"text","id":"button_text","label":"Button text","default":"Start now"},{"type":"url","id":"button_link","label":"Button link"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"center"},{"type":"color","id":"background_color","label":"Background","default":"#111111"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"presets":[{"name":"Call to action"}]}
{% endschema %}
