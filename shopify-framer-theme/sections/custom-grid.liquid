<section class="section custom-grid section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container">
    {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
    <div class="custom-grid__items columns-{{ section.settings.columns }}">
      {% for block in section.blocks %}
        <article class="grid-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}{% render 'responsive-image', image: block.settings.image %}{% endif %}
          <h3 class="grid-card__title">{{ block.settings.title }}</h3>
          <p class="grid-card__text">{{ block.settings.text }}</p>
          {% render 'button', text: block.settings.button_text, link: block.settings.button_link, style: 'secondary' %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{"name":"Custom grid","settings":[{"type":"text","id":"heading","label":"Heading","default":"Custom grid"},{"type":"text","id":"subheading","label":"Subheading"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"left"},{"type":"range","id":"columns","label":"Grid columns","min":2,"max":4,"step":1,"default":3},{"type":"color","id":"background_color","label":"Background","default":"#ffffff"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"blocks":[{"type":"image","name":"Image block","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"title","label":"Title"},{"type":"textarea","id":"text","label":"Text"},{"type":"text","id":"button_text","label":"Button text"},{"type":"url","id":"button_link","label":"Button link"}]}],"presets":[{"name":"Custom grid","blocks":[{"type":"image"},{"type":"image"},{"type":"image"}]}]}
{% endschema %}
