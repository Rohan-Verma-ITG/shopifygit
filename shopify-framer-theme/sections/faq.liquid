<section class="section faq section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container">
    {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
    <div>
      {% for block in section.blocks %}
        <div class="faq__item" {{ block.shopify_attributes }}>
          <button type="button" data-faq-toggle aria-expanded="false" aria-controls="FAQ-{{ section.id }}-{{ forloop.index }}">{{ block.settings.question }}</button>
          <div id="FAQ-{{ section.id }}-{{ forloop.index }}" hidden>
            {{ block.settings.answer }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{"name":"FAQ","settings":[{"type":"text","id":"heading","label":"Heading","default":"Frequently asked questions"},{"type":"text","id":"subheading","label":"Subheading"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"left"},{"type":"color","id":"background_color","label":"Background","default":"#ffffff"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"blocks":[{"type":"text","name":"Text block","settings":[{"type":"text","id":"question","label":"Question"},{"type":"richtext","id":"answer","label":"Answer"}]}],"presets":[{"name":"FAQ","blocks":[{"type":"text"},{"type":"text"},{"type":"text"}]}]}
{% endschema %}
