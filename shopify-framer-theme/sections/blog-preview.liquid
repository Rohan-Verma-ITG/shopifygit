<section class="section blog-preview section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container">
    {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
    <div class="custom-grid__items columns-{{ section.settings.columns }}">
      {% assign blog = blogs[section.settings.blog] %}
      {% for article in blog.articles limit: section.settings.posts_to_show %}
        <article class="grid-card">
          {% render 'responsive-image', image: article.image %}
          <h3 class="grid-card__title">{{ article.title }}</h3>
          <p class="grid-card__text">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{"name":"Blog preview","settings":[{"type":"text","id":"heading","label":"Heading","default":"From the journal"},{"type":"blog","id":"blog","label":"Blog"},{"type":"range","id":"posts_to_show","label":"Posts","min":2,"max":6,"step":1,"default":3},{"type":"range","id":"columns","label":"Columns","min":2,"max":3,"step":1,"default":3},{"type":"text","id":"subheading","label":"Subheading"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"left"},{"type":"color","id":"background_color","label":"Background","default":"#ffffff"},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"presets":[{"name":"Blog preview"}]}
{% endschema %}
