<section class="section featured-collections section-{{ section.id }}" style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--bg:{{ section.settings.background_color }};">
  <div class="container" style="--cw:{{ section.settings.container_width }}px;">
    {% render 'section-header', heading: section.settings.heading, subheading: section.settings.subheading, alignment: section.settings.text_alignment %}
    <div class="featured-collections__grid columns-{{ section.settings.columns }}">
      {% for block in section.blocks %}
        <article class="grid-card" {{ block.shopify_attributes }}>
          {% if block.settings.collection != blank %}
            {% assign collection = block.settings.collection %}
            {% render 'responsive-image', image: collection.featured_image %}
            <h3 class="grid-card__title">{{ collection.title }}</h3>
            <p class="grid-card__text">{{ collection.description | strip_html | truncate: 90 }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{"name":"Featured collections","settings":[{"type":"text","id":"heading","label":"Heading","default":"Featured collections"},{"type":"text","id":"subheading","label":"Subheading","default":"Shop by category"},{"type":"select","id":"text_alignment","label":"Text alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default":"left"},{"type":"range","id":"columns","label":"Grid columns","min":2,"max":4,"step":1,"default":3},{"type":"color","id":"background_color","label":"Background","default":"#ffffff"},{"type":"range","id":"container_width","label":"Container width","min":900,"max":1400,"step":20,"default":1200},{"type":"range","id":"padding_top","label":"Padding top","min":0,"max":160,"step":4,"default":56},{"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":160,"step":4,"default":56}],"blocks":[{"type":"collection","name":"Collection block","settings":[{"type":"collection","id":"collection","label":"Collection"}]}],"presets":[{"name":"Featured collections","blocks":[{"type":"collection"},{"type":"collection"},{"type":"collection"}]}]}
{% endschema %}
